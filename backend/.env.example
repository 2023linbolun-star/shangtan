# 商探AI 后端环境变量配置

# --- 基础服务 ---
DATABASE_URL=postgresql://user:password@localhost:5432/shangtanai
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-here

# --- AI 服务 ---
CLAUDE_API_KEY=your-claude-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# --- 联盟 API 密钥（选品模块数据来源）---

# 淘宝联盟（阿里妈妈）— P0 优先级
# 注册入口：https://pub.alimama.com/
# 流程：淘宝账号登录 → 注册淘宝客 → 媒体备案 → 创建 AppKey
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
TAOBAO_ADZONE_ID=

# 多多进宝（拼多多）— P0 优先级
# 注册入口：https://open.pinduoduo.com/
# 流程：注册多多客 → 身份证实名 → 创建应用 → 绑定 PID
PDD_CLIENT_ID=
PDD_CLIENT_SECRET=
PDD_PID=

# 抖音精选联盟（聚推客）— P0 优先级
# 注册入口：https://www.jutuike.com/
# 流程：注册平台账号 → 个人中心获取 pub_id → 开通 API 权限
JUTUIKE_PUB_ID=

# 1688 开放平台 — P2 优先级
# 注册入口：https://open.1688.com/
# 流程：企业认证 → 创建应用 → 订购解决方案 → 聚石塔部署
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=

# 小红书开放平台 — P1 优先级
# 注册入口：https://open.xiaohongshu.com/
# 流程：注册开发者 → 创建应用 → 申请接口权限
XHS_APP_ID=
XHS_APP_SECRET=

# --- 维易 API（veapi.cn）— 聚合中间层 ---
# 暂时替代各平台官方 API，一个 vekey 调多平台数据
# 注册入口：https://www.veapi.cn/
# 流程：注册账号 → 会员中心 → 接口管理 → 创建密钥
VEAPI_KEY=
VEAPI_PDD_PID=
VEAPI_PDD_CUSTOM=
